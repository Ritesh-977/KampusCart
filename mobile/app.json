{
  "expo": {
    "name": "KampusCart",
    "slug": "kampuscart",
    "version": "1.0.0",
    "orientation": "portrait",
    "backgroundColor": "#0f172a", 
    "userInterfaceStyle": "dark",
    "icon": "./assets/images/icon.png",
    "scheme": "kampuscart",
    "newArchEnabled": true,

    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },

    "ios": {
      "supportsTablet": true,
      "backgroundColor": "#0f172a"
    },
    "android": {
      "backgroundColor": "#0f172a",
      "splash": {
        "image": "./assets/images/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#0f172a"
      },
       "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0B0C10"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize",
      "package": "com.ritesh977.kampuscart"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png",
      "backgroundColor": "#0f172a"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#4f46e5",
          "sounds": []
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "googleWebClientId": "66888588906-ibk5dgbo44bfq8jdk5h98n0bmsd4fsqf.apps.googleusercontent.com",
      "googleAndroidClientId": "66888588906-p8c2f1bhmq3bqrts789s7hs58ok5jucn.apps.googleusercontent.com",
      "eas": {
        "projectId": "2fd5f259-43cf-4cba-a052-8d9206b1882b"
      }
    },
    "owner": "ritesh977"
  }
}